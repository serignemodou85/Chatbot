# Normalise les fins de ligne : LF dans le repo, conversion automatique selon l'OS
* text=auto eol=lf

# Fichiers toujours LF (scripts shell, configs)
*.py    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf

# Fichiers binaires : pas de conversion
*.pdf   binary
*.docx  binary
*.png   binary
*.jpg   binary
