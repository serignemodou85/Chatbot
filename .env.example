# ── Configuration ── .env.example ────────────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter le fichier .env dans Git !

# ── LLM ──────────────────────────────────────────────────────────────────────
# Choisir entre OpenAI (API payante) ou Ollama (Llama 3 local, gratuit)
LLM_PROVIDER=ollama              # "openai" ou "ollama"
LLM_MODEL=llama3                 # "gpt-4o" si OpenAI, "llama3" si Ollama
LLM_TEMPERATURE=0.1              # 0 = déterministe, 1 = créatif

# OpenAI (laisser vide si Ollama)
OPENAI_API_KEY=sk-...

# Ollama (laisser vide si OpenAI)
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=huggingface   # "huggingface" (local) ou "openai"
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=cybersec_docs

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512                   # Taille des chunks en tokens
CHUNK_OVERLAP=64                 # Overlap entre chunks
RETRIEVER_K=4                    # Nombre de chunks retournés par recherche
